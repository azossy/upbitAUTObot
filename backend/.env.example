# 배짱이 v1.0 백엔드 — 환경 변수 예시
# 이 파일을 .env로 복사 후 값 수정

# DB (SQLite, 기본값 사용 가능)
# DATABASE_URL=sqlite+aiosqlite:///./baejjangi.db

# JWT (반드시 변경!)
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_64_char_hex_secret_key_here

# API 키 암호화 (64자 hex)
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# CORS (Flutter 앱 주소. 웹(Chrome) 사용 시 DEBUG=true 권장)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# 텔레그램 (선택)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_DEFAULT_CHAT_ID=

# FCM (선택) — Firebase 서비스 계정 JSON 파일 경로
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# 구글/카카오 로그인 (앱에서 구글·카카오 계정 회원가입 테스트 시 필요)
# 구글: Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > 웹 클라이언트 ID (앱 OAuthConfig.googleWebClientId와 동일)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# 카카오: Kakao Developers > 앱 > 앱 키 > REST API 키
# KAKAO_REST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 이메일 발송 (회원가입 인증·축하 메일). 미설정 시 인증 메일 발송 불가(503)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=앱_비밀번호
# EMAIL_FROM=배짱이 <noreply@example.com>
# VERIFICATION_CODE_EXPIRE_MINUTES=1
# APP_CONTACT_EMAIL=문의용 기본 메일 (발송 메일 하단 안내, 예: baejjangi@example.com)
# APP_CONTACT_EMAIL=baejjangi@example.com

# 디버그 (true 시 CORS 전체 허용 — Flutter 웹 로그인 시 true 로 두세요)
DEBUG=true
